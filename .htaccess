# Plesk applica già il routing tramite Phusion Passenger.
# Se il dominio non passa direttamente all'app Node, questo .htaccess fa da fallback.
PassengerEnabled on
PassengerNodejs /opt/plesk/node/20/bin/node
PassengerStartupFile server.js
PassengerAppType node
PassengerAppRoot /var/www/vhosts/DOMAIN.TLD/httpdocs

# Forza HTTPS (opzionale)
# RewriteEngine On
# RewriteCond %{HTTPS} off
# RewriteRule (.*) https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
